#include<iostream>
using namespace std;

int main() {
	int n;
	int r = 1;
	
	cout << "entr 1 num \n";
	cin >> n;


		while (r < n) {
			string s;
			cin >> s;

		
			if (s == "no" || s == "No" || s == "nO" || s == "NO" ||
				s == "on" || s == "oN" || s == "On" || s == "ON")
				cout << s << " ";

			r++;
		}
		return 0;
	}

