#include<iostream>
using namespace std;

int main() {
	int  n,r=0,t=0;
	int x = 1;
	double o,e;
	
	cout << "enter 1 num \n";
	cin >> n;
	while (x <= n) {
		
		if (x % 2 == 1) {
			cin >> o;
			 r =r+ o;
		}
		else {
			cin >> e;
			t = t + e;
		}

		x = x + 1;


	}
	if (n%2==1)
	     cout << r / ((n+1) / 2.0) << " " << t / ((n-1) / 2.0);
	else 
		cout << r / (n / 2.0) << " " << t / (n / 2.0);

	return 0;

}
