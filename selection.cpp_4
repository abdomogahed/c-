
#include <iostream>
using namespace std;
int main()
{
	int n,n2,n3;
	cout << "enter 3 num\n";
	cin >> n >> n2>>n3;
	if ((n > n2) && (n2 < n3))
		cout << n2;
	else if ((n < n2) && (n < n3))
		cout << n;
	else
		cout << n3;

	return 0;                              //علشان اجيب اصغر رقم من التلاته
}
   
