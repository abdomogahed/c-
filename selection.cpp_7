
#include <iostream>
using namespace std;
int main()
{
	int n,m;
	cin >> n >> m;
	int x = n % 2;
	int r = m % 2;
	if (x == 1 && r == 1)
		cout << n * m;
	else if (x == 0 && r == 0)
		cout << n / m;
	else if (x == 1 && r == 0)
		cout << n + m;
	else if (x == 0 && r == 1)
		cout << n - m;
	




	return 0;
}
   
