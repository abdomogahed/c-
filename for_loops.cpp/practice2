
#include<iostream>
using namespace std;

int main() {
    int num1,num2,sum;

    cout << "enter num1 and num2 and sum: \n";
    cin >> num1 >> num2 >> sum;
    int start1 = 0, start2 = 0;

    while (start1 <= num1) {
        while (start1 + num2 == sum) {
            cout << start1 << " "<<num2<<"\n";

            num2--;
        }
                                     


        start1++;
    }
    return 0;
}

